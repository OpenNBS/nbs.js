{
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "declaration": false,
    "esModuleInterop": true,
    "exactOptionalPropertyTypes": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ESNext"],
    "listFiles": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "build",
    "paths": {
      "~/*": ["./src/*"],
    },
    "rootDir": "src",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "target": "ES2020",
    "verbatimModuleSyntax": true,
  },
  "include": ["src/**/**.ts"],
  "typedocOptions": {
    "categoryOrder": [
      "Highlights",
      "Song",
      "Instrument",
      "Layer",
      "Note",
      "Array Buffer",
      "*",
    ],
    "entryPoints": ["src/index.ts"],
    "githubPages": true,
    "groupOrder": [
      "Classes",
      "Properties",
      "Methods",
      "Functions",
      "Variables",
      "*",
    ],
    "hideGenerator": true,
    "includeVersion": true,
    "name": "nbs.js",
    "navigation": {
      "includeCategories": true,
    },
    "out": "public/docs/dev",
    "plugin": [
      "typedoc-material-theme",
      "typedoc-plugin-mdn-links",
      "typedoc-plugin-include-example",
    ],
    "readme": "none",
    "searchCategoryBoosts": {
      "Array Buffer": 2,
      "Highlights": 5,
      "Instrument": 3,
      "Layer": 3,
      "Note": 3,
      "Song": 4,
    },
    "searchGroupBoosts": {
      "Classes": 1.4,
      "Functions": 1.2,
      "Methods": 1.2,
      "Properties": 1.3,
      "Variables": 1.1,
    },
    "sort": ["static-first", "visibility", "kind", "alphabetical"],
    "themeColor": "#c6a0f6",
    "validation": {
      "notDocumented": true,
    },
  },
}

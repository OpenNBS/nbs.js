{
	"$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							{ "source": ["!:ALIAS:", "!:NODE:"], "type": true },
							":BLANK_LINE:",
							{ "source": [":ALIAS:", ":NODE:"], "type": true },
							":BLANK_LINE:",
							[":BUN:", ":NODE:"],
							":BLANK_LINE:",
							[":ALIAS:", ":PATH:"],
							":BLANK_LINE:"
						]
					}
				},
				"useSortedInterfaceMembers": "on",
				"useSortedKeys": "on"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"includes": ["**", "!public", "!build", "!dist", "!.direnv"],
		"indentStyle": "tab"
	},
	"javascript": {
		"formatter": {
			"bracketSameLine": true,
			"indentStyle": "tab",
			"lineWidth": 100,
			"quoteProperties": "preserve",
			"trailingCommas": "none"
		}
	},
	"json": {
		"formatter": {
			"indentStyle": "tab",
			"trailingCommas": "none"
		}
	},
	"linter": {
		"enabled": true,
		"includes": ["**", "!public", "!build", "!dist", "!.direnv"],
		"rules": {
			"complexity": {
				"useLiteralKeys": "off"
			},
			"correctness": {
				"noUnusedImports": "error"
			},
			"nursery": {
				"useExplicitType": "error"
			},
			"performance": {
				"noDelete": "off"
			},
			"recommended": true,
			"style": {
				"noImplicitBoolean": "error",
				"noNegationElse": "error",
				"useBlockStatements": "error",
				"useCollapsedElseIf": "error",
				"useConsistentArrayType": {
					"level": "error",
					"options": { "syntax": "shorthand" }
				},
				"useConsistentMemberAccessibility": {
					"level": "error",
					"options": {
						"accessibility": "explicit"
					}
				},
				"useFilenamingConvention": {
					"level": "error",
					"options": {
						"filenameCases": ["camelCase", "PascalCase"],
						"requireAscii": true,
						"strictCase": false
					}
				},
				"useImportType": {
					"level": "warn",
					"options": {
						"style": "separatedType"
					}
				},
				"useNamingConvention": {
					"level": "error",
					"options": {
						"strictCase": false
					}
				},
				"useReadonlyClassProperties": {
					"level": "warn",
					"options": {
						"checkAllProperties": true
					}
				}
			},
			"suspicious": {
				"noConsole": { "level": "warn" }
			}
		}
	}
}

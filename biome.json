{
	"$schema": "https://biomejs.dev/schemas/2.3.6/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "off" } } },
	"linter": {
		"enabled": true,
		"includes": ["**", "!public", "!build", "!dist", "!.direnv"],
		"rules": {
			"recommended": true,
			"complexity": {
				"useLiteralKeys": "off"
			},
			"performance": {
				"noDelete": "off"
			},
			"style": {
				"useBlockStatements": "error",
				"useNamingConvention": {
					"level": "error",
					"options": {
						"strictCase": false
					}
				},
				"noImplicitBoolean": "error",
				"noNegationElse": "error",
				"useCollapsedElseIf": "error",
				"useFilenamingConvention": {
					"level": "error",
					"options": {
						"strictCase": false,
						"requireAscii": true,
						"filenameCases": ["camelCase", "PascalCase"]
					}
				},
				"useConsistentArrayType": {
					"level": "error",
					"options": { "syntax": "shorthand" }
				}
			},
			"suspicious": {
				"noConsole": { "level": "warn", "options": { "allow": ["log"] } }
			},
			"correctness": {
				"noUnusedImports": "error"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"includes": ["**", "!public", "!build", "!dist", "!.direnv"],
		"indentStyle": "tab"
	},
	"javascript": {
		"formatter": {
			"quoteProperties": "preserve",
			"trailingCommas": "none",
			"lineWidth": 192,
			"indentStyle": "tab",
			"bracketSameLine": true
		}
	}
}

{
	"author": {
		"name": "OpenNBS",
		"url": "https://opennbs.org"
	},
	"description": "Robust API for reading and writing OpenNBS files.",
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"bun-plugin-dts": "^0.4.0",
		"bun-types": "^1.3.11",
		"type-fest": "^5.5.0",
		"typedoc": "^0.28.18",
		"typedoc-material-theme": "^1.4.1",
		"typedoc-plugin-include-example": "^3.0.2",
		"typedoc-plugin-mdn-links": "^5.1.1",
		"typescript": "^6.0.2"
	},
	"engines": {
		"node": ">=18"
	},
	"exports": {
		".": {
			"bun": "./src/index.ts"
		}
	},
	"files": [
		"dist",
		"changelog.md"
	],
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/OpenNBS"
	},
	"homepage": "https://opennbs.github.io/nbs.js/docs/",
	"keywords": [
		"api",
		"minecraft",
		"nbs",
		"noteblock",
		"onbs"
	],
	"license": "MIT",
	"main": "dist/index.js",
	"name": "@nbsjs/core",
	"packageManager": "bun@1.3.11",
	"publishConfig": {
		"exports": {
			".": "./dist/index.js"
		}
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/OpenNBS/nbs.js.git"
	},
	"scripts": {
		"build": "bun run test && bun run build:bundle",
		"build:bundle": "bun build.ts",
		"build:publish": "bun run build && npm publish",
		"docs": "typedoc",
		"lint": "biome format src --write && biome lint src --write",
		"test": "biome lint src && bun test"
	},
	"sideEffects": false,
	"type": "module",
	"types": "dist/index.d.ts",
	"version": "7.0.0-alpha2"
}
